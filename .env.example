# Copy this file to .env.local and supply your Supabase credentials.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_REDIRECT_URL="https://habitgame.app/auth/callback"
VITE_VAPID_PUBLIC_KEY="your-web-push-public-key"
VITE_APP_VERSION=""
VITE_GIT_SHA=""
VITE_BUILD_TIME=""

# AI Goal Suggestion Edge Function URL
VITE_AI_GOAL_SUGGEST_URL="https://your-project.supabase.co/functions/v1/suggest-goal"
VITE_AI_GOAL_COACH_CHAT_URL="https://your-project.supabase.co/functions/v1/goal-coach-chat"

# OpenAI API key (optional, enables AI habit suggestions + rationale enrichment)
VITE_OPENAI_API_KEY="your-openai-api-key"

# Minigame ticket checkout (Phase 7 placeholders; intentionally blank until
# Stripe products/prices are created)
VITE_STRIPE_PRICE_MINIGAME_TICKETS_10=""
VITE_STRIPE_PRICE_FEEDING_FRENZY_TICKETS_10=""
VITE_STRIPE_PRICE_LUCKY_SPIN_TICKETS_10=""
VITE_STRIPE_PRICE_SPACE_EXCAVATOR_TICKETS_10=""
VITE_STRIPE_PRICE_COMPANION_FEAST_TICKETS_10=""

# Deploying on Vercel? You can also use the Next.js-style names below and
# the build will pick them up automatically.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# NEXT_PUBLIC_SUPABASE_REDIRECT_URL="https://habitgame.app/auth/callback"

# Feature flags
VITE_GOAL_COACH_CONTEXT_EXPERIMENT="false"
VITE_CONFLICT_INVITE_BASE_URL=https://www.peacebetween.com
