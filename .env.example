# Copy this file to .env.local and supply your Supabase credentials.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_REDIRECT_URL="https://habitgame.app/auth/callback"
VITE_VAPID_PUBLIC_KEY="your-web-push-public-key"
VITE_APP_VERSION=""
VITE_GIT_SHA=""
VITE_BUILD_TIME=""

# AI Goal Suggestion Edge Function URL
VITE_AI_GOAL_SUGGEST_URL="https://your-project.supabase.co/functions/v1/suggest-goal"
VITE_AI_GOAL_COACH_CHAT_URL="https://your-project.supabase.co/functions/v1/goal-coach-chat"

# OpenAI API key (optional, enables AI habit suggestions + rationale enrichment)
VITE_OPENAI_API_KEY="your-openai-api-key"

# Minigame ticket checkout (Phase 7 placeholders; intentionally blank until
# Stripe products/prices are created)
VITE_STRIPE_PRICE_MINIGAME_TICKETS_10=""
VITE_STRIPE_PRICE_FEEDING_FRENZY_TICKETS_10=""
VITE_STRIPE_PRICE_LUCKY_SPIN_TICKETS_10=""
VITE_STRIPE_PRICE_SPACE_EXCAVATOR_TICKETS_10=""
VITE_STRIPE_PRICE_COMPANION_FEAST_TICKETS_10=""

# Deploying on Vercel? You can also use the Next.js-style names below and
# the build will pick them up automatically.
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# NEXT_PUBLIC_SUPABASE_REDIRECT_URL="https://habitgame.app/auth/callback"

# Feature flags
VITE_GOAL_COACH_CONTEXT_EXPERIMENT="false"
VITE_CONFLICT_INVITE_BASE_URL=https://www.peacebetween.com

# Players Hand / SPARK UI
# SPARK Players Hand is ON by default. Set this only to disable it:
# accepted disable values: 0, false, no, off
# VITE_PLAYERS_HAND_SPARK_RESULT_ENABLED=false

# DEV-only: shows old/new comparison where supported.
VITE_PLAYERS_HAND_SPARK_COMPARE_ENABLED=false

# Creature theme Stripe price IDs (server-side Supabase Edge Function env vars;
# set these in Supabase secrets, not in the public browser bundle)
STRIPE_PRICE_THEME_SPROUTLING_GROVE=""
STRIPE_PRICE_THEME_SPROUTLING_GROVE_PAIRED=""
STRIPE_PRICE_THEME_EMBER_GLOW=""
STRIPE_PRICE_THEME_EMBER_GLOW_PAIRED=""
STRIPE_PRICE_THEME_AURORA_SKY=""
STRIPE_PRICE_THEME_AURORA_SKY_PAIRED=""
STRIPE_PRICE_THEME_NEBULA_DRIFT=""
STRIPE_PRICE_THEME_NEBULA_DRIFT_PAIRED=""
STRIPE_PRICE_THEME_STARHORN_CELESTIAL=""
STRIPE_PRICE_THEME_STARHORN_CELESTIAL_PAIRED=""

# Creature Pack checkout safety gate. Keep false until odds/refund/purchase-policy review is complete.
VITE_CREATURE_PACK_STRIPE_CHECKOUT_ENABLED="false"

# Creature Pack Stripe price IDs (server-side Supabase Edge Function env vars)
STRIPE_PRICE_CREATURE_PACK_5=""

# Egg Pack Stripe price IDs (server-side Supabase Edge Function env vars)
# See docs/stripe-wiring-checklist.md for setup steps
STRIPE_PRICE_EGG_PACK_SMALL=""
STRIPE_PRICE_EGG_PACK_MEDIUM=""
STRIPE_PRICE_EGG_PACK_LARGE=""

# Dice packs stay in Stripe test mode until the explicit launch switch.
STRIPE_COMMERCE_MODE="test"
STRIPE_PRICE_DICE_PACK_250=""
STRIPE_PRICE_DICE_PACK_500=""
STRIPE_PRICE_DICE_PACK_1200=""
STRIPE_PRICE_DICE_PACK_3000=""
STRIPE_PRICE_DICE_PACK_7500=""
VITE_LANDING_PAGE_TREAT_DEMO_ENABLED="false"

# Membership subscription Stripe price IDs (server-side Supabase Edge Function
# env vars). Create the products/prices in the Stripe dashboard, then paste the
# Price IDs here. Nothing can be charged until these are configured.
# Starting-hypothesis pricing: Member 29/249 NOK, Pro 89/749 NOK, founding 69 NOK.
STRIPE_PRICE_MEMBER_MONTHLY=""
STRIPE_PRICE_MEMBER_YEARLY=""
# STRIPE_PRICE_PRO_MONTHLY / STRIPE_PRICE_PRO_YEARLY may already exist for the
# current single-tier Pro subscription; reuse them here.
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
# Protected early-supporter Pro price (optional; leave blank to disable).
STRIPE_PRICE_PRO_FOUNDING_MONTHLY=""
