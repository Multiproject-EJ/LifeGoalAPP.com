{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "ignoreDeprecations": "5.0",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": ".tmp-energy-feature-tests",
    "noEmit": false
  },
  "include": [
    "src/config/featureAvailability.ts",
    "src/services/featureAccess.ts",
    "src/features/meditation/energyFeatureAccess.ts",
    "src/features/meditation/__tests__/energyFeatureAccess.test.ts"
  ]
}
